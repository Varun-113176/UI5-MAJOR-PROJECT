<mvc:View controllerName="fioriproject.controller.HR"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
     <Page id="_IDGenPage4" title="HR Login" class="sapUiResponsiveContentPadding">

<content>

<VBox id="_IDGenVBox2" height="100%" alignItems="Center" justifyContent="Center">

<Panel id="_IDGenPanel1" width="360px" class="sapUiSmallMargin" backgroundDesign="Solid">

<VBox id="_IDGenVBox3" alignItems="Center" class="sapUiMediumMargin">

<Title id="_IDGenTitle1" text="Login" level="H2" class="sapUiSmallMarginBottom"/>

<Input id="emailInput"
    placeholder="HR Email"
    type="Email"
    width="100%"
    required="true"
    class="sapUiSmallMarginBottom"/>

<Input id="passwordInput"
    placeholder="Password"
    type="Password"
    width="100%"
    required="true"
    class="sapUiSmallMarginBottom"/>

<CheckBox id="_IDGenCheckBox1"
    text="Show Password"
    select="onShowPassword"
    class="sapUiSmallMarginBottom"/>

<Button id="_IDGenButton1"
    text="SIGN IN"
    type="Emphasized"
    width="100%"
    press="onLogin"
    class="sapUiMediumMarginBottom"/>

<Link id="_IDGenLink2"
    text="Forgot Password?"
    press="onForgotPassword"
    class="sapUiTinyMarginBottom"/>

<HBox id="_IDGenHBox2">
    <Text id="_IDGenText1" text="Don't have an account? "/>
    <Link id="_IDGenLink3" text="Sign up" press="onOpenSignup"/>
</HBox>

</VBox>

</Panel>

</VBox>

</content>

</Page>


</mvc:View>